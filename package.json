
{
  "name": "my-playwright-typescript-cucumber",
  "version": "2.0.0",
  "description": "Advanced Playwright TypeScript Cucumber Framework with Multi-Application Support and Restructured Architecture",
  "main": "index.js",
  "scripts": {
    "test": "cucumber-js --config cucumber.config.ts",
    "test:headed": "cross-env HEADED=true cucumber-js --config cucumber.config.ts --profile headed",
    "test:headed:windows": "cross-env HEADED=true cucumber-js --config cucumber.config.ts --profile headed",
    "test:headed:linux": "xvfb-run cross-env HEADED=true cucumber-js --config cucumber.config.ts --profile headed",
    "test:headless": "cucumber-js --config cucumber.config.ts --profile headless",
    "test:smoke": "cucumber-js --config cucumber.config.ts --tags '@smoke'",
    "test:smoke:t3": "cross-env ENV=t3 cucumber-js --config cucumber.config.ts --tags '@smoke'",
    "test:smoke:t5": "cross-env ENV=t5 cucumber-js --config cucumber.config.ts --tags '@smoke'",
    "test:critical": "cucumber-js --config cucumber.config.ts --tags '@critical'",
    "test:regression": "cucumber-js --config cucumber.config.ts --tags '@regression'",
    "test:homepage": "cucumber-js --config cucumber.config.ts --tags '@homepage'",
    "test:frbsf": "cucumber-js --config cucumber.config.ts --tags '@frbsf'",
    "test:app1": "cucumber-js --config cucumber.config.ts --tags '@app1'",
    "test:api": "cucumber-js --config cucumber.config.ts --tags '@api'",
    "test:ui": "cucumber-js --config cucumber.config.ts --tags '@ui'",
    "test:parallel": "cucumber-js --config cucumber.config.ts --parallel 3",
    "test:retry": "cucumber-js --config cucumber.config.ts --retry 2",
    "test:runner": "./scripts/run-tests.sh",
    "test:chromium": "cross-env BROWSER=chromium cucumber-js --config cucumber.config.ts",
    "test:firefox": "cross-env BROWSER=firefox cucumber-js --config cucumber.config.ts",
    "test:webkit": "cross-env BROWSER=webkit cucumber-js --config cucumber.config.ts",
    "test:mobile": "cross-env VIEWPORT=mobile cucumber-js --config cucumber.config.ts --tags '@mobile or @responsive'",
    "test:tablet": "cross-env VIEWPORT=tablet cucumber-js --config cucumber.config.ts --tags '@tablet or @responsive'",
    "test:desktop": "cross-env VIEWPORT=desktop cucumber-js --config cucumber.config.ts --tags '@desktop or @responsive'",
    "test:performance": "cucumber-js --config cucumber.config.ts --tags '@performance'",
    "test:accessibility": "cucumber-js --config cucumber.config.ts --tags '@accessibility'",
    "test:security": "cucumber-js --config cucumber.config.ts --tags '@security'",
    "test:cross-browser": "cucumber-js --config cucumber.config.ts --tags '@cross-browser'",
    "test:dev": "cross-env ENV=dev cucumber-js --config cucumber.config.ts",
    "test:qa": "cross-env ENV=qa cucumber-js --config cucumber.config.ts",
    "test:prod": "cross-env ENV=prod cucumber-js --config cucumber.config.ts --tags '@prod-safe'",
    "report:html": "cucumber-html-reporter --input reports/cucumber-report.json --output reports/cucumber-html/index.html",
    "report:allure": "allure generate reports/allure --clean -o reports/allure-html",
    "report:open": "open reports/cucumber-html/index.html",
    "clean": "rimraf reports/* && mkdir -p reports/{screenshots,videos,traces,cucumber-html,allure}",
    "clean:all": "rimraf reports/* node_modules/.cache .playwright-browsers-installed",
    "setup": "./scripts/setup.sh",
    "lint": "eslint applications api core config --ext .ts",
    "lint:fix": "eslint applications api core config --ext .ts --fix",
    "format": "prettier --write \"applications/**/*.ts\" \"api/**/*.ts\" \"core/**/*.ts\" \"config/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "build": "tsc",
    "validate": "npm run type-check && npm run lint",
    "pretest": "npm run validate",
    "posttest": "npm run report:html",
    "install:browsers": "npx playwright install && npx playwright install-deps",
    "postinstall": "npm run install:browsers",
    "ci:test": "cucumber-js --config cucumber.config.ts --tags 'not @skip' --parallel 5 --retry 3",
    "ci:smoke": "cucumber-js --config cucumber.config.ts --tags '@smoke and not @skip' --parallel 3 --retry 2",
    "debug": "cross-env DEBUG=true HEADED=true cucumber-js --config cucumber.config.ts --tags @debug --parallel 1",
    "dry-run": "cross-env DRY_RUN=true cucumber-js --config cucumber.config.ts --dry-run"
  },
  "keywords": [
    "playwright",
    "typescript",
    "cucumber",
    "bdd",
    "test-automation",
    "frbsf",
    "smoke-testing",
    "page-object-model",
    "multi-application",
    "api-testing",
    "ui-testing",
    "cross-browser",
    "performance",
    "accessibility",
    "security"
  ],
  "author": "Test Automation Team",
  "license": "MIT",
  "devDependencies": {
    "@cucumber/cucumber": "^10.3.1",
    "@playwright/test": "1.58.1",
    "@types/node": "^20.11.17",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "allure-commandline": "^2.24.1",
    "cross-env": "^7.0.3",
    "cucumber-html-reporter": "^7.1.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "http-server": "^14.1.1",
    "multiple-cucumber-html-reporter": "^3.6.2",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "dotenv": "^16.4.1",
    "winston": "^3.11.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "cucumber": {
    "requireModule": [
      "ts-node/register",
      "tsconfig-paths/register"
    ],
    "require": [
      "core/hooks/**/*.ts",
      "applications/**/step-definitions/**/*.ts",
      "api/step-definitions/**/*.ts"
    ],
    "format": [
      "progress-bar",
      "json:reports/cucumber-report.json",
      "html:reports/cucumber-html/index.html"
    ],
    "formatOptions": {
      "snippetInterface": "async-await"
    }
  },
  "eslintConfig": {
    "parser": "@typescript-eslint/parser",
    "plugins": [
      "@typescript-eslint",
      "prettier"
    ],
    "extends": [
      "eslint:recommended",
      "@typescript-eslint/recommended",
      "prettier"
    ],
    "rules": {
      "prettier/prettier": "error",
      "@typescript-eslint/no-unused-vars": "error",
      "@typescript-eslint/no-explicit-any": "warn"
    }
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 100,
    "tabWidth": 2
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/srinivasareddy76/My_Playwright-TypeScript-Cucumber.git"
  },
  "bugs": {
    "url": "https://github.com/srinivasareddy76/My_Playwright-TypeScript-Cucumber/issues"
  },
  "homepage": "https://github.com/srinivasareddy76/My_Playwright-TypeScript-Cucumber#readme"
}
